# EAS Build — archivos que NO se suben al cloud
# Reduce tiempo de upload y superficie de build

# Dependencias y builds cacheados localmente
node_modules/
.expo/
dist/

# Android — caches de Gradle y builds locales
android/.gradle/
android/build/
android/app/build/
android/.kotlin/
android/app/.cxx/
android/app/release/

# iOS — no se usa pero por si acaso
ios/Pods/
ios/build/

# IDE y metadatos
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# Logs y temporales
*.log
*.tmp
.env
.env.local

# Git
.git/
