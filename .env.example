# ============================================
# DUOVIAL — Variables de Entorno (.env.example)
# Copiar a .env.local y completar con valores reales
# NO commitear .env.local al repositorio
# ============================================

# Supabase (prefijo SB_ — Supabase reserva SUPABASE_)
SB_URL=https://wksnlewsffluymawinez.supabase.co
SB_ANON_KEY=tu-publishable-key
SB_SERVICE_ROLE_KEY=tu-service-role-key
SB_PROJECT_REF=wksnlewsffluymawinez

# Mux (Video Processing)
MUX_TOKEN_ID=tu-mux-token-id
MUX_TOKEN_SECRET=tu-mux-token-secret

# Wompi (Payments — Web Dashboard)
WOMPI_PUBLIC_KEY=pub_test_tu-public-key
WOMPI_PRIVATE_KEY=prv_test_tu-private-key
WOMPI_EVENT_SECRET=tus-event-secret
WOMPI_BASE_URL=https://sandbox.wompi.co

# Google Play Billing (Payments — App Android)
GOOGLE_PLAY_PACKAGE_NAME=com.duovial.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}

# OneSignal (Push Notifications)
ONESIGNAL_APP_ID=tu-onesignal-app-id
ONESIGNAL_REST_API_KEY=tu-onesignal-rest-api-key

# App
APP_URL=http://localhost:3000
APP_ENV=development
